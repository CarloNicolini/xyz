// include.mex - MEX compatibility layer for Octave builds
// This file provides MATLAB MEX API compatibility when building with Octave's mkoctfile
// 
// When MATLAB_MEX_FILE is defined (for Octave mkoctfile builds), we include
// the Octave MEX compatibility headers

#ifndef INCLUDE_MEX_H
#define INCLUDE_MEX_H

// Use the compatibility layer from mextools
#include "mextools/mextools.h"

#endif // INCLUDE_MEX_H
